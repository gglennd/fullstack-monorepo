{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "target": "es2023",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": [
      "es2023",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": [
        "./src/*",
        "../../packages/ui/src/*"
      ]
    },
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "strict": true,
    "noEmit": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
